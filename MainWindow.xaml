<Window x:Class="Datarecord.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitleText}"
        Width="1360"
        Height="820"
        WindowState="Maximized"
        MinWidth="1200"
        MinHeight="720"
        Background="{StaticResource PageBackgroundBrush}"
        Closing="Window_OnClosing">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Offset="0" Color="#FFF5F5F7" />
                <GradientStop Offset="0.6" Color="#FFF8FAFF" />
                <GradientStop Offset="1" Color="#FFEFF4FF" />
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 Margin="-120,-140,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#33A5D8FF" />
                    <GradientStop Offset="1" Color="#00A5D8FF" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="360"
                 Height="360"
                 Margin="0,0,-100,-120"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#22B692FF" />
                    <GradientStop Offset="1" Color="#00B692FF" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding HeaderTitleText}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   FontSize="14"
                                   Text="{Binding StatusText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Width="116"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding LoadCommand}"
                                Content="{Binding ReloadText}" />
                        <Button Width="116"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"
                                Content="{Binding SaveLayoutText}" />
                        <Button Width="150"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ReportButton_OnClick"
                                Content="{Binding ReportScreenText}" />
                        <Button Width="150"
                                Height="40"
                                Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="DatabaseSettingsButton_OnClick"
                                Content="{Binding DatabaseSettingsText}" Cursor="Hand" />
                        <Button Width="150"
                                Height="40"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DeleteSelectedCommand}"
                                Content="{Binding DeleteMachineText}" Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding ToolboxTitleText}" />
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="{Binding ToolboxHintText}" />

                        <Border Padding="18"
                                Background="#F3FFFFFF"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22"
                                Cursor="Hand"
                                MouseMove="ToolboxCard_OnMouseMove">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20"
                                                  ShadowDepth="6"
                                                  Opacity="0.10"
                                                  Color="#FF0F172A" />
                            </Border.Effect>

                            <StackPanel>
                                <Border Width="48"
                                        Height="48"
                                        HorizontalAlignment="Left"
                                        Background="#1A007AFF"
                                        CornerRadius="24">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="20"
                                               Text="🏭" />
                                </Border>

                                <TextBlock Margin="0,14,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding EnamelingMachineText}" Cursor="" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ToolboxCardHintText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SectionCardStyle}"
                        Padding="10"
                        Background="#CCFFFFFF"
                        BorderBrush="#30FFFFFF">
                    <ScrollViewer x:Name="DesignSurfaceHost"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False"
                                  Background="Transparent"
                                  SizeChanged="DesignSurfaceHost_OnSizeChanged">
                        <Grid x:Name="DesignSurface"
                              Width="{Binding DesignSurfaceWidth}"
                              Height="{Binding DesignSurfaceHeight}"
                              MinWidth="{Binding ElementName=DesignSurfaceHost, Path=ActualWidth}"
                              MinHeight="{Binding ElementName=DesignSurfaceHost, Path=ActualHeight}"
                              AllowDrop="True"
                              ClipToBounds="True"
                              DragOver="DesignSurface_OnDragOver"
                              Drop="DesignSurface_OnDrop"
                              MouseLeftButtonDown="DesignSurface_OnMouseLeftButtonDown">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#FFFDFEFF" />
                                    <GradientStop Offset="0.45" Color="#FFF7FAFF" />
                                    <GradientStop Offset="1" Color="#FFEEF4FF" />
                                </LinearGradientBrush>
                            </Grid.Background>

                            <Ellipse Width="420"
                                     Height="420"
                                     Margin="-120,-140,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     IsHitTestVisible="False"
                                     Opacity="0.9">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Offset="0" Color="#40B9D7FF" />
                                        <GradientStop Offset="0.55" Color="#16C9DCFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Ellipse Width="360"
                                     Height="360"
                                     Margin="0,0,-80,-100"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Bottom"
                                     IsHitTestVisible="False"
                                     Opacity="0.8">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Offset="0" Color="#30A78BFA" />
                                        <GradientStop Offset="0.6" Color="#12A7C7FF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Border Margin="0"
                                    CornerRadius="26"
                                    IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#22FFFFFF" />
                                        <GradientStop Offset="0.35" Color="#0EFFFFFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Rectangle IsHitTestVisible="False"
                                       Opacity="0.14">
                                <Rectangle.Fill>
                                    <VisualBrush TileMode="Tile"
                                                 Viewport="0,0,36,36"
                                                 ViewportUnits="Absolute"
                                                 Viewbox="0,0,36,36"
                                                 ViewboxUnits="Absolute">
                                        <VisualBrush.Visual>
                                            <Canvas Width="36"
                                                    Height="36">
                                                <Ellipse Width="2"
                                                         Height="2"
                                                         Fill="#FFD8E2F1"
                                                         Canvas.Left="17"
                                                         Canvas.Top="17" />
                                            </Canvas>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                       

                            <ItemsControl ItemsSource="{Binding Machines}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        <Setter Property="Panel.ZIndex" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Panel.ZIndex" Value="10" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Thumb Cursor="SizeAll"
                                               DragDelta="MachineThumb_OnDragDelta"
                                               DragCompleted="MachineThumb_OnDragCompleted"
                                               PreviewMouseLeftButtonDown="MachineThumb_OnPreviewMouseLeftButtonDown"
                                               MouseDoubleClick="MachineThumb_OnMouseDoubleClick">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Width="210"
                                                            MinHeight="188"
                                                            Padding="16"
                                                            CornerRadius="20"
                                                            BorderThickness="1"
                                                            Background="#F7FBFDFF"
                                                            BorderBrush="#4C9AA4B2">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="20"
                                                                              ShadowDepth="6"
                                                                              Opacity="0.18"
                                                                              Color="#FF0F172A" />
                                                        </Border.Effect>

                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Opacity" Value="1" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}"
                                                                                 Value="True">
                                                                        <Setter Property="BorderBrush"
                                                                                Value="#FF0284C7" />
                                                                        <Setter Property="Background"
                                                                                Value="#FCFFFFFF" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsEnabled}"
                                                                                 Value="False">
                                                                        <Setter Property="Opacity"
                                                                                Value="0.56" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <StackPanel DockPanel.Dock="Left">
                                                                    <TextBlock FontSize="17"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               Text="{Binding Name}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Style="{StaticResource CaptionTextStyle}"
                                                                               Text="{Binding IpAddress}" />
                                                                </StackPanel>

                                                                <Border DockPanel.Dock="Right"
                                                                        Padding="10,4"
                                                                        Background="#1A0EA5E9"
                                                                        CornerRadius="12">
                                                                    <TextBlock FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#FF0369A1"
                                                                               Margin="0,9,0,0"
                                                                               Text="{Binding EnabledText}"  />
                                                                </Border>
                                                            </DockPanel>

                                                            <Border Margin="0,14,0,0"
                                                                    Padding="10,8"
                                                                    Background="#FFEFF6FA"
                                                                    CornerRadius="14">
                                                                <StackPanel>
                                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontWeight="Medium"
                                                                               Text="{Binding PlcTypeText}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Style="{StaticResource CaptionTextStyle}"
                                                                               Text="{Binding SampleText}" />
                                                                </StackPanel>
                                                            </Border>

                                                            <Button Margin="0,12,0,0"
                                                                    Height="36"
                                                                    Padding="10,4"
                                                                    FontSize="12"
                                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                                    Click="MachineDetailButton_OnClick"
                                                                    Content="{Binding DataContext.EnterMachineText, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding MachinePropertyTitleText}" />
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="{Binding MachinePropertyHintText}" />

                        <StackPanel IsEnabled="{Binding HasSelectedMachine}">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding MachineNameLabelText}" />
                            <TextBox Margin="0,6,0,14"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="{Binding SelectedMachine.Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding IpAddressLabelText}" />
                            <TextBox Margin="0,6,0,14"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="{Binding SelectedMachine.IpAddress, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding PlcTypeLabelText}" />
                            <ComboBox Margin="0,6,0,14"
                                      Style="{StaticResource FieldComboBoxStyle}"
                                      ItemsSource="{Binding PlcTypes}"
                                      SelectedItem="{Binding SelectedMachine.PlcType}" />

                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding PortLabelText}" />
                            <TextBox Margin="0,6,0,14"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="{Binding SelectedMachine.Port, UpdateSourceTrigger=LostFocus}" />

                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SampleIntervalLabelText}" />
                            <TextBox Margin="0,6,0,14"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="{Binding SelectedMachine.SampleIntervalMs, UpdateSourceTrigger=LostFocus}" />

                            <Button Height="36"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ReconnectSelectedMachineButton_OnClick"
                                    Content="{Binding ReconnectPlcText}" />

                            <TextBlock Margin="0,0,0,14"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedMachine.PlcStatusText}" />

                            <CheckBox IsChecked="{Binding SelectedMachine.IsEnabled}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Content="{Binding EnableMachineText}" />
                        </StackPanel>

                        <Border Margin="0,18,0,0"
                                Padding="16"
                                Background="#F5FFFFFF"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding SuggestionTitleText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SuggestionBodyText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
