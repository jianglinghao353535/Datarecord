<Window x:Class="Datarecord.MachineDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Datarecord.ViewModels"
        Title="機台詳情"
        Width="1240"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Background="#FF0F172A">
    <Grid Margin="16">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FF0B1220" />
                <GradientStop Offset="1" Color="#FF111C2F" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="14"
                Background="#3323344A"
                BorderBrush="#66738AA6"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#FFE2E8F0"
                               Text="{Binding MachineName}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF94A3B8"
                               FontSize="12"
                               Text="單機監控畫面：可記錄參數並依時間區段查詢曲線。" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="110"
                        Height="38"
                        VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CloseButton_OnClick"
                        Content="返回" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False">
            <Grid MinWidth="980" MinHeight="560">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="16"
                        CornerRadius="14"
                        Background="#3323344A"
                        BorderBrush="#66738AA6"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Foreground="#FFE2E8F0" FontSize="19" FontWeight="SemiBold" Text="基本參數" />

                            <Button Margin="0,12,0,0"
                                    Height="36"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="PlcAddressConfigButton_OnClick"
                                    Content="PLC 變數位址設定" />
                            <Button Margin="0,8,0,0"
                                    Height="36"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding RefreshFromPlcCommand}"
                                    Content="重新連線 PLC" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#FF94A3B8"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="{Binding PlcStatusText}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#FF94A3B8"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="啟動後會自動連線 PLC；若失敗可在此手動重連。" />

                            <TextBlock Margin="0,12,0,0" Foreground="#FF94A3B8" FontSize="12" Text="生產速度" />
                            <TextBox Margin="0,6,0,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding ProductionSpeed, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0" Foreground="#FF94A3B8" FontSize="12" Text="生產長度" />
                            <TextBox Margin="0,6,0,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding ProductionLength, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0" Foreground="#FF94A3B8" FontSize="12" Text="生產重量" />
                            <TextBox Margin="0,6,0,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding ProductionWeight, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0" Foreground="#FF94A3B8" FontSize="12" Text="生產狀態" />
                            <TextBox Margin="0,6,0,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding ProductionStatus, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0" Foreground="#FF94A3B8" FontSize="12" Text="目前線徑" />
                            <TextBox Margin="0,6,0,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding CurrentDiameter, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,16,0,8" FontWeight="SemiBold" Foreground="#FFE2E8F0" Text="溫區即時值" />

                            <ItemsControl ItemsSource="{Binding TemperatureZones}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:TemperatureZoneViewModel}">
                                        <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                            <CheckBox Width="88"
                                                      VerticalAlignment="Center"
                                                      Foreground="#FFE2E8F0"
                                                      IsChecked="{Binding IsVisible}"
                                                      Content="{Binding Name}" />
                                            <TextBox Margin="8,0,0,0"
                                                     Style="{StaticResource FieldTextBoxStyle}"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Margin="0,16,0,0"
                                    Height="40"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding RecordSampleCommand}"
                                    Content="記錄目前資料點" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2"
                        Padding="16"
                        CornerRadius="14"
                        Background="#3323344A"
                        BorderBrush="#66738AA6"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="110" />
                                 <ColumnDefinition Width="10" />
                                 <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="曲線類型" />
                                <ComboBox Margin="0,6,0,0"
                                          Style="{StaticResource FieldComboBoxStyle}"
                                          ItemsSource="{Binding ChartTypes}"
                                          SelectedItem="{Binding SelectedChartType}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="開始日期" />
                                <DatePicker Margin="0,6,0,0" SelectedDate="{Binding StartDate}" />
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="開始時間" />
                                <ComboBox Margin="0,6,0,0"
                                          Style="{StaticResource FieldComboBoxStyle}"
                                          ItemsSource="{Binding TimeOptions}"
                                          SelectedItem="{Binding SelectedStartTime}" />
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="結束日期" />
                                <DatePicker Margin="0,6,0,0" SelectedDate="{Binding EndDate}" />
                            </StackPanel>

                            <StackPanel Grid.Column="8">
                                <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="結束時間" />
                                <ComboBox Margin="0,6,0,0"
                                          Style="{StaticResource FieldComboBoxStyle}"
                                          ItemsSource="{Binding TimeOptions}"
                                          SelectedItem="{Binding SelectedEndTime}" />
                            </StackPanel>

                            <Button Grid.Column="10"
                                    Height="38"
                                    Margin="0,20,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding RefreshChartCommand}"
                                    Content="查詢曲線" />

                             <Button Grid.Column="12"
                                     Height="38"
                                     Margin="0,20,0,0"
                                     Style="{StaticResource PrimaryButtonStyle}"
                                     Command="{Binding ReturnToLiveChartCommand}"
                                     Content="返回實時" />
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,10,0,8">
                            <TextBlock Foreground="#FF94A3B8"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="{Binding ChartSummary}" />
                            <ItemsControl Margin="0,6,0,0"
                                          ItemsSource="{Binding TemperatureLegendItems}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedChartType}" Value="Temperature">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:TemperatureLegendItemViewModel}">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="#FF475569" FontSize="11" VerticalAlignment="Center" />
                                            <Grid Width="24" Height="12" Margin="6,0,0,0" VerticalAlignment="Center" ToolTip="{Binding Name}">
                                                <Line X1="1" Y1="6" X2="23" Y2="6" Stroke="{Binding Stroke}" StrokeThickness="2" />
                                                <Path Width="8"
                                                      Height="8"
                                                      Data="{Binding MarkerGeometry}"
                                                      Stretch="Fill"
                                                      Fill="White"
                                                      Stroke="{Binding Stroke}"
                                                      StrokeThickness="1.5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <WrapPanel Margin="0,8,0,0">
                                <CheckBox VerticalAlignment="Center"
                                          Foreground="#FFD6E1EE"
                                          IsChecked="{Binding UseManualYAxis}"
                                          Content="固定 Y 軸" />
                                <TextBlock Margin="14,2,4,0" Foreground="#FF9FB2C8" FontSize="12" Text="最小" />
                                <TextBox Width="90"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Text="{Binding ManualYAxisMin, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="10,2,4,0" Foreground="#FF9FB2C8" FontSize="12" Text="最大" />
                                <TextBox Width="90"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Text="{Binding ManualYAxisMax, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Margin="16,0,0,0"
                                          VerticalAlignment="Center"
                                          Foreground="#FFD6E1EE"
                                          IsChecked="{Binding AutoScaleWhenIdle}"
                                          Content="滑鼠停止時自動縮放" />
                            </WrapPanel>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Padding="12"
                                Background="#FFF4F5F7"
                                BorderBrush="#FFE2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentControl x:Name="TrendChartHost"
                                            PreviewMouseMove="ChartCanvas_OnMouseMove"
                                            MouseLeave="ChartCanvas_OnMouseLeave" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>

