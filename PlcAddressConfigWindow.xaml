<Window x:Class="Datarecord.PlcAddressConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Address Configuration"
        Width="620"
        Height="560"
        MinWidth="560"
        MinHeight="460"
        Background="#FF0F172A"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Border Padding="14"
                CornerRadius="12"
                Background="#3323344A"
                BorderBrush="#66738AA6"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Foreground="#FFE2E8F0" FontSize="20" FontWeight="SemiBold" Text="PLC Address Configuration" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF94A3B8"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="{Binding PlcAddressHint}" />
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="Speed Address" />
                        <TextBox Margin="0,4,0,8" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding PlcAddressProductionSpeed, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="Length Address" />
                        <TextBox Margin="0,4,0,8" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding PlcAddressProductionLength, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="Tension Address" />
                        <TextBox Margin="0,4,0,8" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding PlcAddressProductionWeight, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="Weight Address" />
                        <TextBox Margin="0,4,0,8" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding PlcAddressWeight, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="Diameter Address" />
                        <TextBox Margin="0,4,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding PlcAddressDiameter, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Foreground="#FF94A3B8" FontSize="12" Text="RuningSignal Address (M)" />
                        <TextBox Margin="0,4,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding PlcAddressRuningSignal, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="100"
                            Height="36"
                            Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelButton_OnClick"
                            Content="Close" />
                    <Button Width="100"
                            Height="36"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ConfirmButton_OnClick"
                            Content="Done" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
